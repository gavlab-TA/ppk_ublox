# ─────────────────────────────────────────────────────────────────────────
# ppk — what gets tracked is source only: the ublox-ppk code, the ppk_work
# analysis scripts, and the READMEs. Everything below is large binary GNSS
# data or generated output, kept out of the repo. The READMEs document how to
# regenerate or re-download all of it.
# ─────────────────────────────────────────────────────────────────────────

# --- build output (CMake fetches + builds RTKLIB here) ---
build/
ublox-ppk/build/

# --- raw field data / logs (large, re-recordable) ---
bag/                      # original rosbags (.mcap)
*.mcap
*.bag

# --- CORS base data (public, re-downloadable per README §2) ---
rinex/
*.??d.gz
*.??n.gz
*.??g.gz
*.??o
*.obs

# --- pipeline inputs/outputs (regenerated by running the pipeline) ---
work/
*.ubx
*.gps
*.pos
*.csv

# --- run logs ---
*.log

# --- archives dropped in during setup ---
*.zip
*.tar
*.tar.gz
*.tgz

# --- editor / OS cruft ---
*.asv                     # MATLAB autosave
*.swp
*~
.DS_Store
.vscode/
.idea/
__pycache__/
*.pyc
